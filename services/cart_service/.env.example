DEBUG=true
SECRET_KEY=django-insecure-change-me-in-production

# === Service Configuration ===
SERVICE_NAME=cart_service
SERVICE_PORT=8003

# === Database Configuration ===
DB_NAME=cart_service
DB_USER=cart_service
DB_PASSWORD=cart_service_password
DB_HOST=cart_service_db
DB_PORT=5432

# === Allowed Hosts ===
ALLOWED_HOSTS=localhost,127.0.0.1,cart_service,cart_service:8003

# === CORS Configuration ===
CORS_ALLOW_ALL_ORIGINS=true

# === Upstream Service URLs (for inter-service communication) ===
# These are used by cart_service to communicate with other services
PRODUCT_SERVICE_URL=http://product_service:8006
INVENTORY_SERVICE_URL=http://inventory_service:8007
USER_SERVICE_URL=http://user_service:8001

# === Timeout Settings ===
UPSTREAM_TIMEOUT=5

# === Authentication / Authorization ===
# Internal service key for service-to-service communication
INTERNAL_SERVICE_KEY=your-internal-service-key-here

# === Logging Configuration ===
TIME_ZONE=UTC
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=INFO

# === Redis Configuration (optional, for future use) ===
REDIS_URL=redis://redis:6379/0
