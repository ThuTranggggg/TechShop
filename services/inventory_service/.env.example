# Django Settings
DEBUG=true
SECRET_KEY=django-insecure-change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1,inventory_service

# Service Configuration
SERVICE_NAME=inventory_service
SERVICE_PORT=8007
UPSTREAM_TIMEOUT=5

# Database Configuration
DB_ENGINE=django.db.backends.postgresql
DB_NAME=inventory_service
DB_USER=inventory_service
DB_PASSWORD=inventory_service_password
DB_HOST=inventory_service_db
DB_PORT=5432
DB_CONN_MAX_AGE=60

# Redis Configuration
REDIS_URL=redis://redis:6379/0

# Celery Configuration
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Neo4j Configuration (if needed)
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=neo4jpassword

# LLM Configuration (if needed)
LLM_PROVIDER=placeholder
LLM_API_KEY=placeholder

# Logging
LOG_LEVEL=INFO
DJANGO_LOG_LEVEL=INFO

# CORS
CORS_ALLOW_ALL_ORIGINS=true

# Internal Service Authentication
INTERNAL_SERVICE_KEY=your-internal-service-key-here

# Timezone
TIME_ZONE=UTC

